export interface AssetNode {
  id: string;
  name: string;
  type: 'building' | 'floor' | 'zone' | 'room' | 'system' | 'category' | 'asset';
  children?: AssetNode[];
  metadata?: {
    category?: string;
    model?: string;
    serialNumber?: string;
    installDate?: string;
    lastMaintenance?: string;
    manufacturer?: string;
    capacity?: string;
    location?: string;
    floor?: string;
    zone?: string;
    status?: string;
  };
}

