// Helper to create a copy of an asset (prevents React from hanging on shared references)
const cloneAsset = (templateKey: keyof typeof assetTemplates): AssetNode => {
  const template = assetTemplates[templateKey];
  return {
    ...template,
    id: template.id,
    metadata: template.metadata ? { ...template.metadata } : undefined
  };
};

